---
import Button from "~/components/Button.astro";

interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<Button
  {href}
  target="_blank"
  class="!p-2 [&>svg:first-child]:!size-6 [&>svg:first-child]:!mr-0"
>
  <slot />
  <span class="sr-only">{label}</span>
</Button>
